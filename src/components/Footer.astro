---
// Footer.astro
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "56900000000";
const message = encodeURIComponent("Hola Domus! Quiero hacer un pedido");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${message}`;
---

<footer class="bg-bg-alt border-t border-border py-16 relative overflow-hidden">
  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-12">
      <!-- Logo & Tagline (5 columns) -->
      <div class="md:col-span-5 flex flex-col items-start justify-start">
        <div class="mb-4 max-w-[200px]">
          <img
            src="/logodomus.png"
            alt="Logo de Domus Pizzería Requínoa - Pizzas artesanales y delivery"
            class="w-full h-auto"
            width="200"
            height="70"
          />
        </div>
        <p
          class="font-sans text-cream-muted text-sm leading-relaxed mb-6 max-w-sm"
        >
          Pizzas de autor elaboradas con fermentación lenta de 48 horas y
          horneadas a la perfección en horno de barro artesanal.
        </p>
        <span
          class="font-serif italic text-accent text-base block tracking-wide"
        >
          Pizzas de autor · Masa artesanal · Requinoa
        </span>
      </div>

      <!-- Quick Info / Horarios (3 columns) -->
      <div class="md:col-span-3">
        <h4
          class="font-serif text-lg font-bold text-cream mb-4 tracking-wider uppercase text-xs"
        >
          Horario de Atención
        </h4>
        <ul class="font-sans text-sm text-cream-muted space-y-2">
          <li class="flex justify-between border-b border-border/40 pb-1.5">
            <span>Viernes</span>
            <span class="text-cream">19:00 a 23:00 hrs</span>
          </li>
          <li class="flex justify-between border-b border-border/40 pb-1.5">
            <span>Sábado</span>
            <span class="text-cream">19:00 a 23:00 hrs</span>
          </li>
          <li class="flex justify-between border-b border-border/40 pb-1.5">
            <span>Domingo</span>
            <span class="text-cream">19:00 a 23:00 hrs</span>
          </li>
        </ul>
      </div>

      <!-- Contact & Location (4 columns) -->
      <div class="md:col-span-4">
        <h4
          class="font-serif text-lg font-bold text-cream mb-4 tracking-wider uppercase text-xs"
        >
          Contacto y Ubicación
        </h4>
        <ul class="font-sans text-sm text-cream-muted space-y-4">
          <!-- Address Link to Google Maps -->
          <li class="flex items-start gap-3">
            <svg
              class="w-5 h-5 text-accent mt-0.5 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
              ></path>
            </svg>
            <div>
              <a
                href="https://maps.google.com/?q=Oscar+Castro+29,+Requinoa,+O'Higgins,+Chile"
                target="_blank"
                rel="noopener noreferrer"
                class="text-cream hover:text-accent transition-colors duration-300 font-medium"
              >
                Oscar Castro 29, Requinoa
              </a>
              <span class="block text-xs mt-0.5"
                >Región del Libertador Bernardo O'Higgins</span
              >
            </div>
          </li>

          <!-- Social / Links -->
          <li class="flex gap-4 pt-2">
            <!-- Instagram -->
            <a
              href="https://instagram.com/domuspizzeria.cl"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-2 bg-surface hover:bg-surface/80 border border-border hover:border-accent/40 rounded text-cream hover:text-accent transition-all duration-300"
              aria-label="Instagram de Domus Pizzería"
            >
              <svg
                class="w-4 h-4 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                ></path>
              </svg>
              <span class="text-xs">@domuspizzeria.cl</span>
            </a>

            <!-- WhatsApp Footer Button -->
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-3 py-2 bg-surface hover:bg-surface/80 border border-border hover:border-accent/40 rounded text-[#25D366] hover:text-[#25D366]/80 transition-all duration-300"
              aria-label="WhatsApp Domus"
            >
              <svg
                class="w-4 h-4 fill-current"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.802.001-2.618-1.01-5.082-2.86-6.93C16.37 2.025 13.91 1.012 11.9 1.012c-5.41 0-9.813 4.404-9.816 9.813-.001 1.714.453 3.393 1.317 4.887L2.39 20.21l4.257-1.056zM17.75 14.93c-.314-.157-1.86-.92-2.15-1.025-.29-.105-.5-.157-.71.157-.21.314-.81.103-1.02-.103-.21-.21-.795-.293-1.51-.933-.556-.496-.93-1.11-.104-1.267.086-.157.314-.366.42-.523.104-.157.156-.262.262-.47.105-.21.052-.393-.026-.55-.079-.157-.71-1.71-.973-2.34-.256-.617-.518-.533-.71-.543-.183-.009-.393-.01-.602-.01-.21 0-.55.079-.838.393-.29.314-1.1.107-1.1 2.7 0 .26.05.51.10.76.36 1.48 1.63 2.87 2.94 3.61l.5.28c.45.24.93.36 1.42.36.43 0 .86-.09 1.25-.26.96-.42 1.58-1.1 1.79-1.63.21-.52.21-1 .15-1.1-.06-.1-.26-.15-.57-.31z"
                ></path>
              </svg>
              <span class="text-xs text-cream-muted">Enviar Mensaje</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Copyright -->
    <div
      class="pt-8 border-t border-border/40 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-sans text-cream-muted"
    >
      <span>© 2025 Domus Pizzería. Todos los derechos reservados.</span>
      <span class="flex items-center gap-1.5">
        Hecho en Requinoa con
        <svg
          class="w-3.5 h-3.5 text-accent fill-current"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            fill-rule="evenodd"
            d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
            clip-rule="evenodd"></path>
        </svg>
      </span>
    </div>
  </div>
</footer>
