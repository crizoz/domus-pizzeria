---
// Testimonios.astro
// TODO: reemplazar con reviews reales en producción

const reviews = [
  {
    text: "Nunca pensé encontrar una pizza así en Requinoa. La masa es increíble.",
    author: "María T.",
    role: "Vecina de Requinoa"
  },
  {
    text: "El pepperoni es adictivo. Ya pedimos tres veces en el mismo fin de semana.",
    author: "Carlos R.",
    role: "Cliente Frecuente"
  },
  {
    text: "Por fin una pizzería que no es lo mismo de siempre. Ingredientes de verdad.",
    author: "Francisca M.",
    role: "Amante de la Pizza"
  }
];
---

<section id="testimonios" class="relative py-24 bg-bg overflow-hidden">
  <div class="relative z-10 max-w-6xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-accent font-sans text-xs sm:text-sm font-semibold uppercase tracking-widest block mb-3">Testimonios</span>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-cream mb-4">
        Lo que Dicen Nuestros Clientes
      </h2>
      <div class="h-0.5 w-16 bg-accent mx-auto mb-6"></div>
      <p class="font-sans text-cream-muted text-base sm:text-lg">
        La mejor recompensa a nuestro trabajo es ver a nuestros vecinos disfrutar de cada rebanada.
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <div class="bg-bg-alt border border-border p-8 rounded-lg flex flex-col justify-between hover:border-accent/20 transition-all duration-300 group">
          
          <div>
            <!-- Star Ratings in Gold -->
            <div class="flex gap-1 text-gold mb-6">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote Text -->
            <p class="font-sans text-cream text-base italic leading-relaxed mb-6 group-hover:text-cream transition-colors duration-300">
              "{review.text}"
            </p>
          </div>

          <!-- Author Details -->
          <div class="pt-4 border-t border-border/50 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-surface border border-border flex items-center justify-center font-serif text-accent font-bold">
              {review.author[0]}
            </div>
            <div>
              <cite class="font-serif text-sm font-bold text-cream not-italic block">
                {review.author}
              </cite>
              <span class="font-sans text-[11px] text-cream-muted uppercase tracking-wider block">
                {review.role}
              </span>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Review Call To Action placeholder comment -->
    <div class="text-center mt-12">
      <span class="font-sans text-xs text-cream-muted block">
        // TODO: Enlazar a Google Maps o Instagram para incentivar opiniones públicas
      </span>
    </div>

  </div>
</section>
