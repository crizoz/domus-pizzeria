---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ValorPropuesto from '../components/ValorPropuesto.astro';
import Menu from '../components/Menu.astro';
import Proceso from '../components/Proceso.astro';
import Testimonios from '../components/Testimonios.astro';
import ComoPedir from '../components/ComoPedir.astro';
import Footer from '../components/Footer.astro';
import BotonWhatsApp from '../components/BotonWhatsApp.astro';
---

<Layout>
  <!-- Floating WhatsApp action button (Sticky mobile-only) -->
  <BotonWhatsApp />

  <!-- Main Scrollable Section Tree -->
  <main class="relative z-10">
    <Hero />
    <ValorPropuesto />
    <Menu />
    <Proceso />
    <Testimonios />
    <ComoPedir />
  </main>

  <Footer />
</Layout>
